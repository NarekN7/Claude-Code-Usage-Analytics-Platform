# Database (used by ingestion & analytics services)
DATABASE_URL=postgresql+psycopg2://analytics:analytics@localhost:5432/analytics

# Raw data directory (ETL CLI and optional file paths)
DATA_RAW_DIR=data/raw

# Inter-service URLs (docker service names or localhost)
INGESTION_BASE_URL=http://localhost:8001
ANALYTICS_BASE_URL=http://localhost:8002
GATEWAY_PUBLIC_URL=http://localhost:8000

# Streamlit dashboard calls the gateway
PUBLIC_GATEWAY_URL=http://localhost:8000
